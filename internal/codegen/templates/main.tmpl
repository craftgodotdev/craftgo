// Scaffold generated by craftgo. Safe to edit; will not be overwritten.
//
// Boots the runtime server using the loaded `*config.Config` as the
// single source of truth. Every observability subsystem is gated by
// the matching `cfg.<Section>.Enabled` flag and the exporter selection
// is dispatched at startup so a deployment switches between
// Prometheus pull / OTLP gRPC push / OTLP HTTP push by editing
// `config.yaml` (or setting `CRAFTGO_*` environment variables) - no
// code change required.

package main

import (
	"context"
	"log"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	sdkmetric "go.opentelemetry.io/otel/sdk/metric"
	sdktrace "go.opentelemetry.io/otel/sdk/trace"

	"github.com/craftgodotdev/craftgo/pkg/metrics"
	craftotel "github.com/craftgodotdev/craftgo/pkg/otel"
	"github.com/craftgodotdev/craftgo/pkg/server"

	"{{.ConfigImport}}"
	"{{.RoutesImport}}"
{{- if .HasMiddlewares}}
	"{{.MiddlewareImport}}"
{{- end}}
	"{{.SvccontextImport}}"
)

func main() {
	cfg, err := config.Load(config.Path())
	if err != nil {
		log.Fatalf("config: %v", err)
	}

	ctx := context.Background()

	tracerProvider, err := initTracer(ctx, cfg)
	if err != nil {
		log.Fatalf("otel: %v", err)
	}

	metricsProvider, adminSrv, err := initMetrics(ctx, cfg)
	if err != nil {
		log.Fatalf("metrics: %v", err)
	}

	svc := svccontext.NewServiceContext(cfg)
{{- if .HasMiddlewares}}

	// Each design-declared middleware lives on the embedded
	// Middlewares struct of ServiceContext. Wire each field once at
	// startup with whatever params your impl needs.
{{- range .Middlewares}}
	svc.{{.}} = middleware.New{{.}}Middleware()
{{- end}}
{{- end}}

	// Build the Server and attach runtime globals via Use. Order
	// matters: OTel opens the span first so AccessLog sees the trace
	// ids on ctx (via `WithContext`), and the same `otelhttp.NewHandler`
	// invocation records `http.server.duration` / `request.size` /
	// `response.size` against the configured MeterProvider - no
	// separate metrics middleware is needed.
	srv := server.New(svc)
	srv.Use(craftotel.HTTPMiddleware(cfg.OTel.ServiceName))
	srv.Use(server.AccessLog(srv.Logger()))
	// Global per-request guards. Per-method `@timeout` / `@maxBodySize`
	// decorators wrap inner so they can tighten (never loosen) these
	// defaults. Zero values from config skip the wrap entirely.
	if cfg.Server.HandlerTimeout > 0 {
		srv.Use(server.Timeout(cfg.Server.HandlerTimeout))
	}
	if cfg.Server.MaxBodySize > 0 {
		srv.Use(server.BodyLimit(cfg.Server.MaxBodySize))
	}
	if cfg.Server.Compression.Enabled {
		srv.Use(server.Compress(server.CompressOptions{
			MinSize: cfg.Server.Compression.MinSize,
			Level:   cfg.Server.Compression.Level,
		}))
	}

	// One call wires every service. The umbrella RegisterAll is
	// generated from the DSL service set on every `craftgo gen`.
	routes.RegisterAll(srv, svc)

	go func() {
		log.Printf("listening on %s (api)", cfg.Server.Addr)
		if err := srv.Start(cfg.Server.Addr); err != nil && err != http.ErrServerClosed {
			log.Fatal(err)
		}
	}()

	stop := make(chan os.Signal, 1)
	signal.Notify(stop, syscall.SIGINT, syscall.SIGTERM)
	<-stop

	shutdownCtx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()
	_ = srv.Stop(shutdownCtx)
	if adminSrv != nil {
		_ = metrics.ShutdownAdmin(shutdownCtx, adminSrv)
	}
	if metricsProvider != nil {
		// Drain any pending OTLP push batch before exit. No-op for
		// pull-only setups; important for push so the final histogram
		// snapshot reaches the collector.
		_ = metricsProvider.Shutdown(shutdownCtx)
	}
	if tracerProvider != nil {
		_ = tracerProvider.Shutdown(shutdownCtx)
	}
}

// initTracer dispatches the OTel tracer setup based on cfg.OTel.
// Disabled returns nil; "otlp_grpc" / "otlp_http" attach the matching
// OTLP exporter; "stdout" prints spans to stdout for local debugging;
// any other value (including "none") falls back to an in-process
// TracerProvider with no exporter - spans get valid IDs (so trace_id
// flows into log lines) but go nowhere.
func initTracer(ctx context.Context, cfg *config.Config) (*sdktrace.TracerProvider, error) {
	if !cfg.OTel.Enabled {
		return nil, nil
	}
	opts := []craftotel.Option{craftotel.WithServiceName(cfg.OTel.ServiceName)}
	switch cfg.OTel.Exporter {
	case "otlp_grpc":
		opts = append(opts, craftotel.WithOTLPgRPCExporter(ctx, cfg.OTel.Endpoint))
	case "otlp_http":
		opts = append(opts, craftotel.WithOTLPHTTPExporter(ctx, cfg.OTel.Endpoint))
	case "stdout":
		opts = append(opts, craftotel.WithStdoutExporter())
	}
	return craftotel.Init(opts...)
}

// initMetrics dispatches the OTel meter setup + admin scrape listener
// based on cfg.Metrics. "prometheus" wires a pull exporter and starts
// the admin listener on cfg.Metrics.AdminAddr; "otlp_grpc" /
// "otlp_http" wire the matching push exporter (no admin listener);
// "none" installs a meter without any exporter (rare; testing only).
func initMetrics(ctx context.Context, cfg *config.Config) (*sdkmetric.MeterProvider, *http.Server, error) {
	if !cfg.Metrics.Enabled {
		return nil, nil, nil
	}
	var (
		opts          []metrics.Option
		startScrape   bool
		runtimeStats  bool
	)
	switch cfg.Metrics.Exporter {
	case "otlp_grpc":
		opts = append(opts, metrics.WithOTLPgRPCReader(ctx, cfg.Metrics.Endpoint))
	case "otlp_http":
		opts = append(opts, metrics.WithOTLPHTTPReader(ctx, cfg.Metrics.Endpoint))
	case "none":
		// no readers - meter installed but silent
	default:
		// "prometheus" + any unknown value default to scrape so a
		// typo never silently turns metrics off.
		opts = append(opts, metrics.WithPrometheusReader())
		startScrape = true
		runtimeStats = true
	}

	provider, err := metrics.Init(opts...)
	if err != nil {
		return nil, nil, err
	}
	if runtimeStats {
		// Surface go_* / process_* alongside the OTel-bridged
		// http.server.* histograms - same convenience InitDefault
		// gave callers before the config-driven dispatch.
		_ = metrics.RegisterRuntimeCollectors()
	}

	if !startScrape {
		return provider, nil, nil
	}
	adminSrv, adminErrCh := metrics.StartAdmin(cfg.Metrics.AdminAddr, metrics.WithPath(cfg.Metrics.Path))
	go func() {
		if err := <-adminErrCh; err != nil {
			log.Printf("admin metrics listener: %v", err)
		}
	}()
	log.Printf("metrics scrape listening on %s%s", cfg.Metrics.AdminAddr, cfg.Metrics.Path)
	return provider, adminSrv, nil
}
