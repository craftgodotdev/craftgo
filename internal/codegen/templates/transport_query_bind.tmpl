{{- /*
transport_query_bind.tmpl emits one query-parameter binding block per
field. The five named shapes cover every (array / single) × (parser /
no parser) × (optional / required) × (cast / no cast) combination the
DSL produces; renderQueryBindLine picks the right shape by name and
hands it a pre-computed payload so the template never has to branch on
type primitives - it just slots strings.

Shape catalogue:
  - directSlice         []string, no cast → straight Query() map lookup
  - directSingle        single string (any cast) → Get + optional wrap
  - arrayString         []string with cast → loop + wrapped append
  - arrayParsed         []numeric/bool → loop + parse + wrapped append
  - optionalStringNoCast *string → guard + addr-of raw value
  - optionalStringCast   *Alias → guard + cast + addr-of typed value
  - singleParsed        numeric/bool single → guard + parse + assign
*/ -}}

{{define "directSlice" -}}
req.{{.GoName}} = r.URL.Query()[{{.DSLNameQuoted}}]
{{- end}}

{{define "directSingle" -}}
req.{{.GoName}} = {{.Wrap}}
{{- end}}

{{define "arrayString" -}}
for _, _v := range r.URL.Query()[{{.DSLNameQuoted}}] {
	req.{{.GoName}} = append(req.{{.GoName}}, {{.Wrap}})
}
{{- end}}

{{define "arrayParsed" -}}
for _, _v := range r.URL.Query()[{{.DSLNameQuoted}}] {
	_n, _err := {{.ParseCall}}
	if _err != nil {
		http.Error(w, {{.DSLNameQuoted}}+": invalid {{.Label}} value: "+_err.Error(), http.StatusBadRequest)
		return
	}
	req.{{.GoName}} = append(req.{{.GoName}}, {{.Wrap}})
}
{{- end}}

{{define "optionalStringNoCast" -}}
if _v := r.URL.Query().Get({{.DSLNameQuoted}}); _v != "" {
	req.{{.GoName}} = &_v
}
{{- end}}

{{define "optionalStringCast" -}}
if _v := r.URL.Query().Get({{.DSLNameQuoted}}); _v != "" {
	_w := {{.Wrap}}
	req.{{.GoName}} = &_w
}
{{- end}}

{{define "singleParsed" -}}
if _v := r.URL.Query().Get({{.DSLNameQuoted}}); _v != "" {
	_n, _err := {{.ParseCall}}
	if _err != nil {
		http.Error(w, {{.DSLNameQuoted}}+": invalid {{.Label}} value: "+_err.Error(), http.StatusBadRequest)
		return
	}
	req.{{.GoName}} = {{.Wrap}}
}
{{- end}}
