# craftgo.design.yaml — project manifest read by every CLI command.
# Uncomment optional blocks below as you need them.
#
# This file lives at the root of your design folder. The folder name
# is arbitrary (`design`, `contracts/v1`, `apis`, ...) — every
# `.craftgo` file in the same directory or a descendant is parsed at
# gen time. Run `craftgo gen` from the design folder, or pass
# `-f <design-folder>` from anywhere else.
#
# The Go module path is read from go.mod at gen time (walking up
# from the project root), so the manifest itself does NOT declare
# `package:`. Make sure `go mod init <module>` has been run before
# `craftgo gen`.

# Output paths are resolved against the project root. Per-service
# buckets are created automatically under the directory paths below
# at gen time.
output:
  types:      ./internal/types
  handler:    ./internal/handler
  routes:     ./internal/routes
  logic:      ./internal/logic
  middleware: ./internal/middleware
  svccontext: ./svccontext/svccontext.go
  openapi:    ./docs/openapi.yaml
  config:     ./config              # runtime config package (config.go +
                                    # config.yaml + example.config.yaml).
                                    # main.go reads <config>/config.yaml at
                                    # boot; svccontext.NewServiceContext
                                    # takes the loaded *config.Config.
  # main:     ./cmd/server/main.go  # generated bootstrap main file
  # main:     "-"                   # opt out of main.go scaffolding (also
                                    # skips config/ and svccontext/, useful
                                    # for test fixtures that ship their own
                                    # boot wiring)

# OpenAPI metadata flows into the generated openapi.yaml's info /
# servers / components blocks.
openapi:
  title:    My API
  version:  1.0.0
  basePath: /api

  # Security schemes referenced from `@security(<name>, ...)` in
  # the DSL. The semantic analyser cross-checks every reference
  # against this map — adding `@security(foo, ...)` requires a
  # matching entry here. Uncomment + edit when you wire authentication.
  # securitySchemes:
  #   # Bearer-token JWT — typical service-level default. Reference
  #   # via `@security(bearer)` on the service or method.
  #   bearer:
  #     type: http
  #     scheme: bearer
  #     bearerFormat: JWT
  #   # OAuth2 with scopes — reference via
  #   # `@security(oauth2, scopes: ["users:write"])` on the method.
  #   oauth2:
  #     type: oauth2
  #   # API-key in a header / query / cookie — reference via
  #   # `@security(apiKey)`.
  #   apiKey:
  #     type: apiKey
  #     in: header        # one of: header, query, cookie
  #     name: X-API-Key

