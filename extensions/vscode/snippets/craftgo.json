{
  "package": {
    "prefix": "pkg",
    "body": ["package ${1:name}", "$0"],
    "description": "Package declaration"
  },
  "import": {
    "prefix": "imp",
    "body": ["import \"${1:path}\"$0"],
    "description": "Import another package"
  },
  "type": {
    "prefix": "t",
    "body": ["type ${1:Name} {", "\t$0", "}"],
    "description": "Type declaration"
  },
  "enum": {
    "prefix": "e",
    "body": ["enum ${1:Name} {", "\t${2:Value1}", "\t${3:Value2}", "}$0"],
    "description": "Enum declaration"
  },
  "error": {
    "prefix": "err",
    "body": ["error ${1|BadRequest,Unauthorized,Forbidden,NotFound,Conflict,UnprocessableEntity,Internal|} ${2:Name}$0"],
    "description": "Error declaration with category"
  },
  "scalar": {
    "prefix": "scal",
    "body": ["scalar ${1:Name} ${2|string,int,int64,float64,bool|}$0"],
    "description": "Scalar (newtype) declaration"
  },
  "middleware": {
    "prefix": "mw",
    "body": ["middleware ${1:Name}(${2})$0"],
    "description": "Middleware declaration"
  },
  "service": {
    "prefix": "srv",
    "body": [
      "@prefix(\"/${1:base}\")",
      "@tags(${2:tag})",
      "service ${3:Name}Service {",
      "\t$0",
      "}"
    ],
    "description": "Service block with prefix and tags"
  },
  "extend service": {
    "prefix": "esrv",
    "body": ["extend service ${1:Name}Service {", "\t$0", "}"],
    "description": "Extend an existing service"
  },
  "method get": {
    "prefix": "get",
    "body": [
      "@doc(\"${1:summary}\")",
      "get ${2:OpName} /${3:path} {",
      "\trequest   ${4:Req}",
      "\tresponse  ${5:Resp}",
      "}$0"
    ],
    "description": "GET endpoint"
  },
  "method post": {
    "prefix": "post",
    "body": [
      "@doc(\"${1:summary}\")",
      "post ${2:OpName} /${3:path} {",
      "\trequest   ${4:Req}",
      "\tresponse  ${5:Resp}",
      "}$0"
    ],
    "description": "POST endpoint"
  },
  "method put": {
    "prefix": "put",
    "body": [
      "@doc(\"${1:summary}\")",
      "put ${2:OpName} /${3:path} {",
      "\trequest   ${4:Req}",
      "\tresponse  ${5:Resp}",
      "}$0"
    ],
    "description": "PUT endpoint"
  },
  "method patch": {
    "prefix": "patch",
    "body": [
      "@doc(\"${1:summary}\")",
      "patch ${2:OpName} /${3:path} {",
      "\trequest   ${4:Req}",
      "\tresponse  ${5:Resp}",
      "}$0"
    ],
    "description": "PATCH endpoint"
  },
  "method delete": {
    "prefix": "del",
    "body": [
      "@doc(\"${1:summary}\")",
      "delete ${2:OpName} /${3:path} {",
      "\trequest   ${4:Req}",
      "\tresponse  ${5:Resp}",
      "}$0"
    ],
    "description": "DELETE endpoint"
  },
  "stream method": {
    "prefix": "stream",
    "body": [
      "@doc(\"${1:summary}\")",
      "${2|get,post|} ${3:OpName} /${4:path} {",
      "\trequest   ${5:Req}",
      "\tstream    ${6|sse,ndjson,jsonl,raw|} ${7:Event}",
      "}$0"
    ],
    "description": "Streaming endpoint"
  },
  "request": {
    "prefix": "req",
    "body": ["request   ${1:Type}$0"],
    "description": "Method request line"
  },
  "response": {
    "prefix": "resp",
    "body": ["response  ${1:Type}$0"],
    "description": "Method response line"
  },
  "field required string": {
    "prefix": "fstr",
    "body": ["${1:name} string @required @length(${2:1}, ${3:200})$0"],
    "description": "Required string field with length bounds"
  },
  "field optional string": {
    "prefix": "fstr?",
    "body": ["${1:name} string? @maxLength(${2:200})$0"],
    "description": "Optional string field"
  },
  "field id": {
    "prefix": "fid",
    "body": ["${1:id} string @path @required @length(1, 64)$0"],
    "description": "Path-bound id field"
  },
  "doc decorator": {
    "prefix": "@doc",
    "body": ["@doc(\"${1:description}\")$0"],
    "description": "@doc decorator"
  },
  "deprecated decorator": {
    "prefix": "@dep",
    "body": ["@deprecated(\"${1:reason}\")$0"],
    "description": "@deprecated decorator"
  }
}
