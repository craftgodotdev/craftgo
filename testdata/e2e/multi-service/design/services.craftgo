package design

// Pong, Order and Item live in shared/contracts/. The CLI follows this
// import and merges those files into the same logical `design` package.
import "shared/contracts"

@prefix("/orders")
service OrdersService {
    // Ping the orders service.
    get Ping {
        response  Pong
    }

    // Latest returns the most recently placed order.
    get Latest /latest {
        response  Order
    }
}

@prefix("/catalog")
service CatalogService {
    // Ping the catalog service.
    get Ping {
        response  Pong
    }

    // Featured returns the catalog's hero item.
    get Featured /featured {
        response  Item
    }
}
