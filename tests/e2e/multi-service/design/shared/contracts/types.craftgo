// Shared contracts pulled in by services.craftgo via
// `import "shared/contracts"`. Same package as the importer: an import
// spreads one logical package across folders.
package design

// Pong is the simple response for the ping endpoints.
type Pong {
	name string
}

// Order represents a customer order in the orders service.
type Order {
	id    string
	total int
}

// Item represents a catalog item in the catalog service.
type Item {
	sku   string
	price int    @gte(0)
}
