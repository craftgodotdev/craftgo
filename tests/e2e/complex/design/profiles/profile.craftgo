package design

// Profile and the matching request/response shapes. ContactInfo lives in
// `contacts/`, Address lives next to this file but pulls in Coords from
// `geo/` — proves transitive imports survive gen.
import "contacts"

// Profile is the wire-level shape of a user profile. Notice the nesting:
// Profile contains ContactInfo, plus a slice of Addresses, each of which
// optionally embeds a Coords value.
type Profile {
	id          string
	displayName string              @length(1, 50)
	contacts    ContactInfo
	addresses   Address[]           @minItems(1) @maxItems(5)
	tags        string[]            @maxItems(10)
	meta        map<string, string>
	age         int?
}

// CreateProfileReq mirrors Profile minus the id (the server assigns it).
// Same validators, applied at the top of the request decode.
type CreateProfileReq {
	displayName string              @length(1, 50)
	contacts    ContactInfo
	addresses   Address[]           @minItems(1) @maxItems(5)
	tags        string[]            @maxItems(10)
	meta        map<string, string>
	age         int?
}

// GetProfileReq carries only the path id; the handler binds it from
// {id} before calling logic.
type GetProfileReq {
	id string
}

// ListProfilesResp pages a slice of profiles back to the client.
type ListProfilesResp {
	items Profile[]
	total int
}

// PatchProfileReq mixes every binding kind in a single request: path id,
// query dryRun, header idempotency key, cookie session, and a body
// payload containing the new display name. The handler binds each from
// the matching part of the HTTP request.
type PatchProfileReq {
	id             string @path
	dryRun         string @query
	idempotencyKey string @header
	sessionToken   string @cookie
	displayName    string @length(1, 50)
}

// PatchProfileResp is the symmetric response: echoes back every value
// the handler bound so the e2e test can assert end-to-end.
type PatchProfileResp {
	id             string
	dryRun         string
	idempotencyKey string
	sessionToken   string
	displayName    string
}
