// Package `nested` exercises every recursive / nested-composition
// shape the codegen has to handle: plain nesting, deep chains,
// optional self-references, slices / maps of nested types, multi-
// dimensional slices of nested types, mutual recursion, and the
// interaction of recursion with cross-field validators + the
// `@sensitive` opt-out.
//
// Every type-name here is local to this package, so the request /
// response bodies in `service.craftgo` can refer to them without
// prefix.
package nested

// ---------------------------------------------------------------
// Plain nested - the canonical "User has an Address" case.
// ---------------------------------------------------------------

// Address is the simplest leaf nested type. The two string fields
// carry independent @minLength so the generated Validate() returns
// the FIRST violation when either is empty.
type Address {
	street string @minLength(1)
	city   string @minLength(1)
}

// User couples an addr to a self-referential optional boss + an
// optional alias for the cross-field-validator showcase below.
//
// `boss User?` is the SELF-OPTIONAL recursion case: codegen must
// emit `Boss *User` in Go and gate the recursive Validate() call
// with `if v.Boss != nil { ... }`.
//
// `@requiresOneOf(name, alias)` rides on User to demonstrate that
// type-level cross-field validators COMPOSE with nested validation
// - the cross-field check runs AFTER every nested Validate() call.
@requiresOneOf(name, alias)
type User {
	addr   Address
	name   string?
	alias  string?
	// SENSITIVE FIELD - codegen MUST omit the JSON tag (`json:"-"`)
	// and skip the field in OpenAPI; the validator side does NOT
	// emit per-field checks for `@sensitive` flagged fields anyway,
	// so the nested cascade simply has no entry for `secretNotes`.
	secretNotes string @sensitive
	// Self-optional - the marquee recursion case.
	boss   User?
}

// ---------------------------------------------------------------
// Deep nesting - 4+ levels.
// ---------------------------------------------------------------

// Person → Home → Room → Furniture chain. Each level adds one
// nested call to the validator dispatch, demonstrating that the
// cascade carries the deepest violation back to the top.
type Person {
	home Home
}

// Home owns a slice of nested Rooms. The slice variant tests that
// codegen emits a `for i0 := range v.Rooms` loop with the recursive
// Validate() inside.
type Home {
	rooms Room[]
}

// Room owns a slice of Furniture. Two consecutive slice-of-nested
// fields in the chain (Home.rooms, Room.furniture) verify that
// each level scopes its own loop index.
type Room {
	furniture Furniture[]
}

// Furniture is the deepest leaf; its own validators (`@minLength`,
// `@gte`) anchor the cascade.
type Furniture {
	name   string @minLength(1)
	weight int    @gte(0)
}

// ---------------------------------------------------------------
// Slice / map / multi-dim of nested.
// ---------------------------------------------------------------

// Team gates `members` with both the array-level bound decorators
// (`@minItems`, `@maxItems`) AND per-element nested validation.
// Codegen produces:
//
//   if len(v.Members) < 1 { ... }
//   if len(v.Members) > 50 { ... }
//   for i0 := range v.Members { v.Members[i0].Validate() }
type Team {
	members User[] @minItems(1) @maxItems(50)
}

// Org demonstrates OPTIONAL slice of nested. The Go field is
// `Teams []Team` but the wire field is `omitempty`; codegen still
// emits the per-element loop without a nil-guard because Go's
// `range` on a nil slice is a no-op.
type Org {
	teams Team[]?
}

// Catalog stores users by string key. Map values are NOT recursed
// into by the v1 codegen (see nestedValidateCall in
// internal/codegen/validate_emit.go - maps are explicitly skipped).
// This entry pins that behaviour so a regression surfaces in the
// inspection step.
type Catalog {
	users map<string, User>
}

// Matrix is the 2-D slice of nested case. Codegen emits two nested
// for-loops; each loop indexes one bracket dim.
type Matrix {
	grid Node[][]
}

// Cube is the 3-D slice of nested case. Three nested for-loops
// drive the recursive Validate() call on the innermost element.
type Cube {
	space Node[][][]
}

// ---------------------------------------------------------------
// Direct + mutual recursion.
// ---------------------------------------------------------------

// Node is the canonical recursive tree node. `children Node[]` is
// the slice-of-self pattern; the codegen emits ONE Validate()
// function per type so the recursion stays bounded at runtime.
type Node {
	id       string @minLength(1)
	children Node[]
}

// A and B form the mutual-recursion pair. Each side carries an
// OPTIONAL pointer to the other; codegen must emit:
//
//   func (v *A) Validate() error { ... if v.B != nil { v.B.Validate() } }
//   func (v *B) Validate() error { ... if v.A != nil { v.A.Validate() } }
//
// Go's compiler handles the cycle through pointer fields; the
// hazard is purely a codegen one (don't recurse INTO Validate
// generation per-call - generate once per TYPE).
type A {
	id string
	b  B?
}

type B {
	id string
	a  A?
}

// ---------------------------------------------------------------
// Generic-instantiation-like nested envelope.
// ---------------------------------------------------------------

// Order is a tiny leaf used by ListPage below. Stays minimal so
// the page envelope's validate cascade has a single field to
// reach.
type Order {
	id string @minLength(1)
}

// ListPage simulates the "page wrapper" pattern: an array of one
// nested type plus an optional metadata of another. Both arms
// exercise the validate cascade in one type body.
type ListPage {
	items Order[]
	meta  Address?
}
