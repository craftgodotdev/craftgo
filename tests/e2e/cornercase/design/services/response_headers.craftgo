// response_headers.craftgo exercises @header / @cookie on the
// response side. Those fields are routed through http.Header.Set /
// http.SetCookie before the JSON body is encoded, and the OpenAPI
// emitter surfaces them as response.headers entries instead of body
// properties.
//
// It also exercises NON-string header / cookie values: the generated
// writer formats int / bool / enum (and scalars of those) to their
// wire string via strconv, mirroring the request-side binder.
package services

import "shared"

// PaginatedResp carries a JSON list plus response-only fields:
// `X-Total-Count` advertises the total (a non-string int, formatted via
// strconv.Itoa), `X-Next-Page` is an optional header (nil-guarded so an
// absent value writes no header at all), `has_more` is a bool cookie
// (strconv.FormatBool), and the `session` cookie refreshes the auth
// token without a separate /refresh round trip. All four stay out of
// the JSON body via the runtime header/cookie writers.
type PaginatedResp {
	items    shared.ID[]
	count    int       @header("X-Total-Count")
	traceId  shared.ID @header("X-Trace-Id")    // string scalar → string(...)
	nextPage string?   @header("X-Next-Page")
	hasMore  bool      @cookie("has_more")
	session  string    @cookie("session_id")
}

// RateLimited surfaces the back-off hint on a non-string `Retry-After`
// response header — exercising @header value formatting on the error
// path (errorResponseBindings) the same way PaginatedResp does for the
// success path.
error TooManyRequests RateLimited {
	retryAfter int @header("Retry-After")
}

// HeaderEchoService demonstrates that the JSON body schema and the
// response.headers map come out of the SAME response struct: split
// purely by `@header` / `@cookie` decorators on individual fields.
@prefix("/header-echo")
service HeaderEchoService {
	@doc("List items with the total surfaced via response header and the auth cookie refreshed in passing.")
	@errors(RateLimited)
	get ListItems / {
		response PaginatedResp
	}
}
