// Package `combine` exercises the cross-decorator combination surface:
// the presence-state matrix (`plain`, `?`, `@nullable`, `?@nullable`,
// `@default`), every stacked decorator pairing the generator can be
// asked to emit on a single field, and the type-level cross-field
// validators (`@requiresOneOf`, `@mutuallyExclusive`) interacting with
// per-field decorators on the same struct.
//
// The presence file pins the canonical four-state + default matrix on
// `string` so the generated Go type, the validator emit-order, the
// JSON unmarshal path, and the OpenAPI `required[]` / `type` /
// `default` keys can be diffed row-by-row. Nullability is emitted in the
// OpenAPI 3.1 canonical form - `type: [string, "null"]` - not the
// removed 3.0 `nullable: true` keyword.
package combine

// PresenceMatrix is the canonical presence-state matrix.
//
// Row map (DSL → Go → wire contract):
//
//   plain        string                          → string   required, non-null
//   optional     string?                         → *string  optional, may be omitted OR null
//   nullable     string @nullable                → *string  required, value may be JSON null
//   bothNullable string? @nullable               → *string  4-state (same as optional, redundant @nullable)
//   defValue     string? @default("d")           → *string  optional + pre-fill (the `?` is mandatory under @default)
//   defNullable  string? @nullable @default("d") → *string  optional + nullable + pre-fill
//
// Wire contract diffs row-by-row (OpenAPI 3.1: null rides the `type`
// list, so a nullable string is `type: [string, "null"]`):
//
//   plain:        required[] yes, type: string
//   optional:     required[] no,  type: [string, "null"]
//   nullable:     required[] yes, type: [string, "null"]
//   bothNullable: required[] no,  type: [string, "null"]
//   defValue:     required[] no,  type: [string, "null"], default: "d"
//   defNullable:  required[] no,  type: [string, "null"], default: "d"
//
// The `bothNullable` and `defNullable` rows trip the "redundant
// @nullable on `T?`" warning (the optionality already permits null);
// the linter should surface that without rejecting the file.
type PresenceMatrix {
	plain        string
	optional     string?
	nullable     string  @nullable
	bothNullable string? @nullable
	defValue     string? @default("d")
	defNullable  string? @nullable @default("d")
}
