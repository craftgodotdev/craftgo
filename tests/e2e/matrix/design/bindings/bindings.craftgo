// Package `bindings` exercises the request-binding decorators (`@path`,
// `@query`, `@header`, `@cookie`, `@body`, `@form`) plus the typing
// rules that gate each - `@path` requires string-shape, `@query`
// accepts the full primitive + array matrix, `@header` / `@cookie` are
// string-only, and `@form` carries the `file` upload pair.
//
// Each request DTO below lives next to a service method in
// service.craftgo so the codegen has a real handler to drive at gen
// time. The clusters are organised top-down by binding kind.
package bindings

// ---------------------------------------------------------------
// Path bindings.
//
// `@path` requires the field to be string-shaped - `string`, a
// string-backed scalar, or a string-backed enum. The wire name is the
// DSL field name (the explicit-name form `@path("user_id")` is parsed
// but the codegen always emits `r.PathValue(<f.Name>)`).
// ---------------------------------------------------------------

// UUID is a string-backed scalar that adds @format(uuid) inheritance
// to every field that references it. Used in PathScalarReq so the
// path binder lands a typed alias instead of a bare string.
scalar UUID string @format(uuid)

// Color is a string-backed enum (bare-ident form, default string
// values are the ident text). Exercised across path, query, and the
// cookie binders so every wire-format binder gets the enum cast +
// validate path.
enum Color {
	Red
	Green
	Blue
}

// PathStringReq is the canonical path-bound DTO: a single `id string`
// field that auto-binds (or explicitly binds) to the `{id}` segment
// of `/items/{id}`.
type PathStringReq {
	id string @path @length(1, 64)
}

// PathScalarReq replaces the bare `string` with the UUID scalar. The
// generator emits `req.Id = UUID(r.PathValue("id"))` so the field
// lands as the typed alias and the inherited @format(uuid) validator
// fires at request time.
type PathScalarReq {
	id UUID @path
}

// PathEnumReq drives the enum-typed @path binder. The wire value is
// a string ("red" / "green" / "blue"); req.Validate() rejects any
// value outside the enum's declared set.
type PathEnumReq {
	c Color @path
}

// PathExplicitNameReq exercises the `@path("user_id")` form where the
// DSL field name (`userId`) differs from the URL placeholder
// (`{user_id}`). The codegen binds against the explicit wire name so
// the generated handler reads `r.PathValue("user_id")`.
type PathExplicitNameReq {
	userId string @path("user_id") @length(1, 64)
}

// PathIntReq is the DELIBERATELY-INVALID shape: `@path` requires
// string-shape and `int` is not. Codegen rejects this at gen time
// with a clear error message - uncomment the field + PathIntProbe
// method to reproduce. Captured diagnostic:
//
//   bindings.craftgo:NN:9: field PathIntReq.id: @path requires a
//   string-backed field (string, string scalar, or string enum) -
//   got int
//
// type PathIntReq {
// 	id int @path
// }

// ---------------------------------------------------------------
// Query bindings.
//
// `@query` accepts every primitive (string / bool / int* / uint* /
// float*) plus arrays of those, scalars / enums of either kind, and
// the optional `?` form of any of them. An absent param and a
// present-but-empty one (`?x=`) both leave the field at nil.
// ---------------------------------------------------------------

// QueryStringReq exercises the optional-string query path. The
// generator emits a nil-guarded pointer write because Go has a clean
// "absent vs empty" sentinel for `*string`.
type QueryStringReq {
	q string? @query
}

// QueryIntReq is the optional-int query path. The binder reads the raw
// string, parses it on presence, and writes a `*int`; an absent or empty
// `?page=` leaves the field nil. `@gte(1)` runs on the dereferenced value.
type QueryIntReq {
	page int? @query @gte(1)
}

// QueryIntRequiredReq is the required-int variant: an absent `page`
// leaves the field at its zero value, and `@gte(1)` then rejects it.
type QueryIntRequiredReq {
	page int @query @gte(1)
}

// QueryBoolReq is the optional-bool query path: present â†’ `*bool`,
// absent / empty â†’ nil.
type QueryBoolReq {
	active bool? @query
}

// QueryEnumReq drives the enum cast path through @query. Enums are
// string-shape on the wire, so optional is fine - the binder reads
// the raw string and casts up to the Color alias.
type QueryEnumReq {
	c Color? @query
}

// QueryArrayStringReq exercises the `[]string @query` shape. The
// generator emits `req.Tags = r.URL.Query()["tags"]` - repeated
// `?tags=a&tags=b` lands as `["a", "b"]`. CSV (`?tags=a,b`) is NOT
// auto-split.
type QueryArrayStringReq {
	tags string[]? @query
}

// QueryArrayIntReq drives the `[]int @query` shape. Each repeated
// value goes through strconv.ParseInt + append; one bad value fails
// the whole request with HTTP 400.
type QueryArrayIntReq {
	ids int[]? @query
}

// QueryRequiredReq is the canonical "always required, capped" query
// param. Codegen emits the int parser with @gte / @lte gates so
// `?limit=0` and `?limit=101` are both rejected.
type QueryRequiredReq {
	limit int @query @gte(1) @lte(100)
}

// QueryArrayEnumDefaultReq drives the enum-array @query @default path.
// The slice is pre-filled with the wire values of the default members
// ([Red, Blue]); the binder must REPLACE that pre-fill when the param
// is present, not append to it - so `?colors=green` yields ["green"],
// never ["red", "green", "blue"]. The has-default oracle the binder
// consults resolves the enum-member array literal so it agrees with the
// pre-fill that emitted the default.
type QueryArrayEnumDefaultReq {
	colors Color[]? @query @default([Red, Blue])
}

// ---------------------------------------------------------------
// Header / cookie bindings.
//
// Both are string-shape only on the wire. Codegen rejects @header /
// @cookie on a non-string-shape field at gen time. Optional `string?`
// is fine - the absent header reads as the empty string, which the
// generator stores as a nil pointer.
// ---------------------------------------------------------------

// HeaderReq carries a required X-API-Key style header. The explicit
// `@header("X-API-Key")` argument names the wire-side header so the
// generated handler reads from the canonical HTTP name rather than
// the Go field's PascalCase form (`r.Header.Get("X-API-Key")`).
type HeaderReq {
	apiKey string @header("X-API-Key")
}

// HeaderOptionalReq exercises a required header bound to an explicit
// wire name (`X-Trace-Id`). The binder treats an absent header as the
// empty string.
type HeaderOptionalReq {
	traceId string @header("X-Trace-Id")
}

// CookieReq drives the cookie binder with an explicit wire name - the
// runtime fetches the cookie named `session_id`.
type CookieReq {
	session string @cookie("session_id")
}

// ---------------------------------------------------------------
// Body & form bindings.
//
// `@body` carries a single field that holds the whole request
// payload (useful for raw-string / opaque blob shapes). `@form` pairs
// with `file` fields for multipart uploads and accepts the
// @maxSize + @mimeTypes validator pair.
// ---------------------------------------------------------------

// BodyExplicitReq has one explicit `@body`-bound field. Useful when
// the wire payload is an opaque string (signed token, raw markdown,
// etc.) rather than a JSON object.
type BodyExplicitReq {
	payload string @body
}

// FormFileReq drives the multipart-form upload path. The `file` type
// renders as `*multipart.FileHeader`; the @maxSize + @mimeTypes
// validator pair enforces the upload envelope at boundary-validate
// time.
type FormFileReq {
	id   string @path @length(1, 64)
	file file   @form @maxSize(5MB) @mimeTypes("image/png", "image/jpeg")
}
