package design

// Second `extend service` block — admin-only methods. A single service
// can be split across as many extend files as needed; the semantic
// phase merges them in source order.
extend service ProfileService {
	// AdminListProfiles is auth-gated. The `@middlewares` decorator
	// wraps the handler with ProfileAuth at gen time; unauthenticated
	// callers get a 401 from the middleware before the handler runs.
	@middlewares(ProfileAuth)
	@security(ProfileAuth)
	get AdminListProfiles /admin/profiles {
		response ListProfilesResp
	}
}
