package design

// AdminService lives in its own folder (design/admin/); a service
// defined apart from `api.craftgo` produces the same routes it would
// inline. The import resolver merges this file into the package, then
// route gen stitches:
//
//   basePath(/api) + @prefix(/v1/admin) + method-path(/dashboard)
//
// → `/api/v1/admin/dashboard`. @prefix drives the URL; @group nests this
// service's generated handlers and service stubs under
// internal/transport/admin-service/ops/v2/ (and the matching service/
// tree) without touching the route or OpenAPI *path*, and its value also
// rides along as an OpenAPI tag - so these operations carry
// [admin, ops, ops/v2]. The service-level @middlewares wraps every method
// without the decorator on each one individually.
@prefix("/v1/admin")
@group("ops/v2")
@middlewares(ProfileAuth)
@tags(admin, ops)
service AdminService {
	// DashboardStats reuses ListProfilesResp as a minimal stat payload.
	get DashboardStats /dashboard {
		response ListProfilesResp
	}

	// Health is path-less so it falls back to the kebab-cased method
	// name. End URL: `/api/v1/admin/health`.
	get Health {}

	// Snapshot stacks an additional method-level middleware on top of
	// the service-level ProfileAuth chain. The combined order at gen
	// time is `[ProfileAuth, RequestStamp]` — ProfileAuth wraps
	// outermost, so unauthenticated callers never reach RequestStamp.
	// Method-level `@tags(snapshot)` adds to the service-level tags
	// list, NOT replacing it — clients see [admin, ops, snapshot].
	@middlewares(RequestStamp)
	@tags(snapshot)
	get Snapshot /snapshot {
		response ListProfilesResp
	}
}
