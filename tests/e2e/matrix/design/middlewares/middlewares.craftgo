package design

// All middleware declarations live in `design/middlewares/`. Other
// design files (api.craftgo, admin/admin-service.craftgo) reference
// these names via `@middlewares(...)` decorators; the import resolver
// merges this file into the same logical package so the names are
// visible everywhere.

// ProfileAuth is the bearer-token middleware. The runtime resolves it
// against the project's `middleware.NewAuthRequiredMiddleware(...)`
// implementation, wired in main.go.
middleware ProfileAuth

// RequestStamp adds a response header for downstream tracing.
middleware RequestStamp
