package design

// PfAddress is a postal address. Country is the ISO 3166-1 alpha-2 code,
// so the length validator pins it to exactly two characters.
type PfAddress {
	street  string  @length(1, 200)
	city    string  @length(1, 100)
	country string  @length(2, 2)
	postal  string?
	coords  Coords?
}
