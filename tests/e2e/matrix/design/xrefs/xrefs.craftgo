// Package xrefs is the cross-package matrix fixture. Every `xshared.X`
// reference here exercises one (kind × shape × binding/decorator) cell
// of the matrix, covering resolver lookup, validate emit, transport
// bind, and openapi schema for qualified refs.
//
// One field per matrix cell keeps each cell isolated.
package xrefs

import "xshared"

// ----- ENUM matrix -----

// XEnumScalar exercises direct + optional + array enum field shapes.
// The validator emits a switch-case per shape; the OpenAPI schema
// inlines the enum values list (or $refs the enum schema).
type XEnumScalar {
	flat  xshared.XColor
	maybe xshared.XColor?
	many  xshared.XColor[]
}

// XEnumMaps exercises enum keys / values in maps. The walker emits a
// switch on either side independently (key-only, value-only, or both).
type XEnumMaps {
	byString map<string, xshared.XColor>          // value-only switch
	byEnum   map<xshared.XColor, string>          // key-only switch
	bothEnum map<xshared.XColor, xshared.XColor>  // both-side switch
}

// XEnumDefault exercises `@default(Red)` on a cross-pkg enum field:
// the enum value is referenced by bare ident, not a string literal,
// since enum identity is by name. Transport pre-fill qualifies the
// constant (`xshared.XColorRed`) and registers the xshared import on
// the handler file.
type XEnumDefault {
	color xshared.XColor? @default(Red)
}

// ----- SCALAR matrix -----

// XScalarFields exercises cross-pkg scalar refs in every shape. Each
// field inherits the scalar's @format / @length chain via the project
// ScalarTable, and the required-empty check on `flat` resolves the
// scalar's underlying primitive through the resolver.
type XScalarFields {
	flat   xshared.XEmail
	maybe  xshared.XEmail?
	many   xshared.XEmail[]
	stamps xshared.XTimestamp[]
}

// XScalarBindings exercises scalar refs at wire binding sites. The
// transport handler emits qualified casts:
//   - `req.Path = xshared.XEmail(r.PathValue("path"))`
//   - `req.Q = xshared.XEmail(r.URL.Query().Get("q"))`
type XScalarBindings {
	path  xshared.XEmail   @path
	q     xshared.XEmail   @query
	hdr   xshared.XEmail   @header
	ck    xshared.XEmail   @cookie
	num   xshared.XNodeID  @query
}

// ----- TYPE matrix -----

// XTypeFields exercises cross-pkg type refs in every shape. Each field
// dispatches `v.Field.Validate()` (or per-element when nested).
type XTypeFields {
	flat  xshared.XOwner
	maybe xshared.XOwner?
	many  xshared.XOwner[]
	byKey map<string, xshared.XOwner>
}

// XTypeMixin exercises mixin embedding from cross-pkg. The `XAudit`
// mixin's fields land via Go field-promotion; the host's Validate
// calls `v.XAudit.Validate()` explicitly since Go method promotion
// doesn't auto-invoke on the host.
type XTypeMixin {
	xshared.XAudit
	id string @length(1, 64)
}

// ----- GENERIC matrix -----

// XGeneric exercises cross-pkg generic instantiations. Each argument
// kind takes a different generic-arg resolution path. OpenAPI
// registers one component per (decl, args) tuple under the
// FastAPI-style `XBagOfFoo` naming, not bare `xshared.XBag`.
type XGeneric {
	ofLocal   xshared.XBag<XLocalItem>
	ofXType   xshared.XBag<xshared.XOwner>
	ofPrim    xshared.XBag<string>
	ofMap     xshared.XBag<map<string, xshared.XColor>>
}

type XLocalItem { id string }

// ----- ERROR + service matrix -----

type XGetReq {
	id string @path @length(1, 64)
}

// XSearchReq exercises cross-package scalar binding casts. The /search
// handler emits qualified casts (`req.Q = xshared.XEmail(r.URL.Query()
// .Get("q"))`) so the assignment type-checks against the
// `*xshared.XEmail` field.
type XSearchReq {
	q     xshared.XEmail   @query
	hdr   xshared.XEmail   @header
	ck    xshared.XEmail   @cookie
	num   xshared.XNodeID  @query
}

@prefix("/xrefs")
service XRefsService {
	@doc("Pins cross-package @errors reference. xshared.XNotFound must register as a component schema AND appear in the operation's responses[404].body schema.")
	@errors(xshared.XNotFound)
	get GetItem /items/{id} {
		request  XGetReq
		response xshared.XOwner
	}

	@doc("Pins cross-package response generic. Component must be `XBagOfXOwner`, not dangling `xshared.XBag`.")
	get ListItems /items {
		response xshared.XBag<xshared.XOwner>
	}

	@doc("Pins cross-package scalar BINDING casts. Handler must emit `req.Q = xshared.XEmail(r.URL.Query().Get(\"q\"))` (qualified cast) — bare strings fail to compile against the *xshared.XEmail field type.")
	get Search /search {
		request  XSearchReq
		response xshared.XOwner
	}

	@doc("Pins cross-package enum `@default` pre-fill in transport. Body decode must seed `req.Color = &__d` with `__d := xshared.XColorRed` before JSON.Decode runs; without resolver the default literal silently drops because the local pkg.Enums miss.")
	post PostDefault /defaults {
		request  XEnumDefault
		response xshared.XOwner
	}
}
