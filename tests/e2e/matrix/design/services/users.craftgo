// Package `services` exercises the CROSS-PACKAGE consumption side
// of the import / mixin / scalar / extend matrix. Every interesting
// edge sits here:
//
//   - `import "shared"` - bare-package import; the implicit alias
//     `shared` is what `shared.<Name>` references resolve through.
//   - `shared.ID` / `shared.Email` - cross-package scalar refs.
//     The generated Go field type lands as `string` (the underlying
//     primitive) but the validator inherits the scalar's @length /
//     @format constraint stack.
//   - `shared.Audit` / `shared.Pagination` mixin - cross-package
//     embedded type. The mixin syntax is implicit (bare qualified
//     ident inside a `type { ... }` body) so the parser threads
//     `shared.Audit` through `parseTypeMember`'s mixin branch.
//   - `@middlewares(shared.AuthRequired)` at service level -
//     qualified middleware reference from another package.
//   - `@errors(shared.NotFoundErr, shared.ConflictErr)` on a
//     per-method decorator - qualified error references.
//
// The companion `users_admin.craftgo` adds the `extend service`
// half of the showcase; `projects.craftgo` covers the same-package
// reuse path (UserRef declared here is consumed there without a
// qualifier).
package services

// UserRef is the lightweight handle: id + email. Used as a BODY
// request (POST CreateUser, POST BanUser) and as the owner field
// of services.Project. Both fields are cross-package scalars
// (`shared.ID`, `shared.Email`) resolved across the import edge.
type UserRef {
	id    shared.ID
	email shared.Email
}

// GetUserReq is the path-only request for GetUser / DeleteUser. The
// `id` field is a local `string @path` that replays shared.ID's length
// cap inline via @length(1, 64).
type GetUserReq {
	id string @path @length(1, 64)
}

// User is the full entity. Embeds `shared.Audit` via the implicit
// CROSS-PACKAGE MIXIN form (`shared.Audit` alone on a body line is
// a mixin reference, not a field) so the createdAt / updatedAt /
// createdBy bookkeeping lands at the wire root without a nested
// envelope.
type User {
	shared.Audit
	id    shared.ID
	email shared.Email
	name  string @minLength(1)
}

// ListUsersReq embeds `shared.Pagination` cross-package. The
// implicit mixin form makes the limit / cursor / total fields land
// at the request root, and the optional `query` slot adds the free-
// text filter on top.
type ListUsersReq {
	shared.Pagination
	query string?
}

// ListUsersResp wraps a page of Users with the canonical pagination
// envelope. `meta` is a NESTED reference (not a mixin) so the
// pagination summary lands in its own JSON sub-object - the
// distinction between "embed at root" (mixin) and "embed as nested
// object" (field) is captured cleanly across these two consumers.
type ListUsersResp {
	items User[]
	meta  shared.Pagination
}

// UserService is the canonical CRUD surface. Service-level
// `@middlewares(shared.AuthRequired)` runs the cross-package
// AuthRequired frame on every method; the per-method
// `@errors(shared.NotFoundErr, shared.ConflictErr)` decorator on
// DeleteUser surfaces the cross-package error envelopes in the
// generated OpenAPI document.
@prefix("/users")
@middlewares(shared.AuthRequired)
service UserService {
	get ListUsers / {
		request  ListUsersReq
		response ListUsersResp
	}

	get GetUser /{id} {
		request  GetUserReq
		response User
	}

	post CreateUser / {
		request  User
		response User
	}

	@errors(shared.NotFoundErr, shared.ConflictErr)
	delete DeleteUser /{id} {
		request  GetUserReq
		response User
	}
}
